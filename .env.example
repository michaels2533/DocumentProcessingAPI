# Required: used for embeddings (locked at deploy time) and, when
# LLM_PROVIDER=openai, for chat/classification as well.
OPENAI_API_KEY=sk-your-key-here

# Chat/classification provider. One of: openai (default), anthropic, ollama.
LLM_PROVIDER=openai

# Per-provider chat model overrides (defaults shown).
OPENAI_CHAT_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-3-5-haiku-latest
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b

POSTGRES_USER=docproc
POSTGRES_PASSWORD=docproc_secret
POSTGRES_DB=docproc
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://docproc:docproc_secret@db:5432/docproc

# Redis broker used by the Arq worker for background document processing.
REDIS_URL=redis://redis:6379/0
#Test DB Credentials
TEST_POSTGRES_USER=testuser
TEST_POSTGRES_PASSWORD=testpassword
TEST_POSTGRES_DB=test_db
TEST_POSTGRES_HOST=testdb
TEST_POSTGRES_PORT=5434
TEST_DATABASE_URL=postgresql+asyncpg://testuser:testpassword@testdb:5434/testuser